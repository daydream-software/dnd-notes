{
  "name": "dnd-notes",
  "private": true,
  "version": "0.1.0",
  "description": "D&D note-taking app starter with React, Material UI, and Node.js",
  "workspaces": [
    "packages/theme",
    "packages/portal-utils",
    "packages/postgres-migrations",
    "platform/keycloak-jwt",
    "apps/web",
    "apps/api",
    "apps/control-plane",
    "apps/operator-portal",
    "apps/customer-portal"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:control-plane": "npm run dev --workspace apps/control-plane",
    "dev:operator-portal": "npm run dev --workspace apps/operator-portal",
    "dev:customer-portal": "npm run dev --workspace apps/customer-portal",
    "k3d:up": "bash ./scripts/k3d/up.sh",
    "k3d:down": "bash ./scripts/k3d/down.sh",
    "k3d:status": "bash ./scripts/k3d/status.sh",
    "k3d:bootstrap": "bash ./scripts/k3d/bootstrap.sh",
    "k3d:build-image": "bash ./scripts/k3d/build-image.sh --name Tenant --dockerfile Dockerfile --repo ghcr.io/daydream-software/dnd-notes --tag k3d",
    "k3d:build-control-plane-image": "bash ./scripts/k3d/build-image.sh --name Control-plane --dockerfile docker/control-plane/Dockerfile --repo ghcr.io/daydream-software/dnd-notes-control-plane --tag k3d",
    "k3d:build-operator-portal-image": "bash ./scripts/k3d/build-image.sh --name Operator-portal --dockerfile docker/portal/Dockerfile --repo ghcr.io/daydream-software/dnd-notes-operator-portal --tag k3d --build-arg PORTAL_NAME=operator-portal",
    "k3d:build-customer-portal-image": "bash ./scripts/k3d/build-image.sh --name Customer-portal --dockerfile docker/portal/Dockerfile --repo ghcr.io/daydream-software/dnd-notes-customer-portal --tag k3d --build-arg PORTAL_NAME=customer-portal",
    "k3d:smoke": "bash ./scripts/k3d/smoke.sh",
    "k3d:full-stack-smoke": "bash ./scripts/k3d/full-stack-smoke.sh",
    "k3d:tenant-api-override": "bash ./scripts/k3d/tenant-api-override.sh",
    "k3d:operator-portal-override": "bash ./scripts/k3d/operator-portal-override.sh",
    "k3d:customer-portal-override": "bash ./scripts/k3d/customer-portal-override.sh",
    "platform:validate": "bash ./scripts/platform/validate-manifests.sh",
    "validate:keycloak-themes": "bash ./scripts/platform/validate-keycloak-theme-sync.sh",
    "copilot:yolo": "bash ./scripts/copilot-yolo.sh",
    "copilot:wait-review": "node --import tsx ./scripts/wait-copilot-review.ts",
    "lint:web": "npm run lint --workspace apps/web",
    "lint:operator-portal": "npm run lint --workspace apps/operator-portal",
    "lint:customer-portal": "npm run lint --workspace apps/customer-portal",
    "build:web": "npm run build --workspace apps/web",
    "build:operator-portal": "npm run build --workspace apps/operator-portal",
    "build:customer-portal": "npm run build --workspace apps/customer-portal",
    "test:keycloak-jwt": "npm run test --workspace platform/keycloak-jwt --",
    "test:ci:keycloak-jwt": "npm run test:ci --workspace platform/keycloak-jwt --",
    "test:portal-utils": "npm run test --workspace packages/portal-utils --",
    "test:ci:portal-utils": "npm run test:ci --workspace packages/portal-utils --",
    "test:web": "npm run test --workspace apps/web --",
    "test:api": "npm run test --workspace apps/api --",
    "test:control-plane": "npm run test --workspace apps/control-plane --",
    "test:operator-portal": "npm run test --workspace apps/operator-portal --",
    "test:customer-portal": "npm run test --workspace apps/customer-portal --",
    "test:ci:web": "npm run test:ci --workspace apps/web --",
    "test:ci:api": "npm run test:ci --workspace apps/api --",
    "test:ci:control-plane": "npm run test:ci --workspace apps/control-plane --",
    "test:ci:operator-portal": "npm run test:ci --workspace apps/operator-portal --",
    "test:ci:customer-portal": "npm run test:ci --workspace apps/customer-portal --",
    "test:ci": "node ./scripts/run-ci-tests.mjs",
    "coverage:ci": "node ./scripts/merge-ci-coverage.mjs",
    "seed:data": "npm run seed:data --workspace apps/api",
    "reset:data": "npm run reset:data --workspace apps/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:md": "markdownlint-cli2",
    "test": "npm run test:keycloak-jwt && npm run test:portal-utils && npm run test:web && npm run test:api && npm run test:control-plane && npm run test:operator-portal && npm run test:customer-portal",
    "prepare": "node ./scripts/prepare.mjs",
    "postinstall": "node ./scripts/build-portal-utils.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daydream-software/dnd-notes.git"
  },
  "license": "FSL-1.1-MIT",
  "bugs": {
    "url": "https://github.com/daydream-software/dnd-notes/issues"
  },
  "homepage": "https://github.com/daydream-software/dnd-notes#readme",
  "engines": {
    "node": ">=22.21.1 <23"
  },
  "overrides": {
    "ajv@~8.13.0": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.4",
    "@xmldom/xmldom": "^0.9.10",
    "c8": "^10.1.3",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.22.1"
  }
}
