PORT=3001
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/control_plane
CONTROL_PLANE_ADMIN_TOKEN=replace-me
CONTROL_PLANE_AUTH_MODE=static
CONTROL_PLANE_KEYCLOAK_URL=http://localhost:8080
CONTROL_PLANE_KEYCLOAK_REALM=dnd-notes-dev
CONTROL_PLANE_KEYCLOAK_CLIENT_ID=dnd-notes-control-plane
CONTROL_PLANE_KEYCLOAK_REQUIRED_ROLES=control-plane-admin,control-plane-workforce
CONTROL_PLANE_TRUST_PROXY=false
NODE_ENV=development
CONTROL_PLANE_ENABLE_PROVISIONING=false
TENANT_KEYCLOAK_URL=http://localhost:8080
TENANT_KEYCLOAK_JWKS_URL=
TENANT_KEYCLOAK_REALM=dnd-notes-dev
TENANT_BASE_DOMAIN=dnd-notes.test
TENANT_IMAGE_REPOSITORY=ghcr.io/daydream-software/dnd-notes
TENANT_DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres
TENANT_DATABASE_RUNTIME_URL=postgresql://runtime-template:placeholder@localhost:5432/postgres?sslmode=disable
TENANT_IMAGE_PULL_SECRET=
TENANT_PUBLIC_SCHEME=https
TENANT_APP_PORT=3000
TENANT_READY_TIMEOUT_MS=120000

# Backup destination: "disabled" (default, 501 on backup routes) or "azure-blob"
BACKUP_DESTINATION=disabled
# Required when BACKUP_DESTINATION=azure-blob
AZURE_STORAGE_ACCOUNT=
# Container name for tenant backups (default: tenant-backups)
AZURE_STORAGE_CONTAINER=tenant-backups
# Auth: provide exactly one of SAS_TOKEN or CONNECTION_STRING
# SAS token (recommended for test releases; time-bounded scope)
AZURE_STORAGE_SAS_TOKEN=
# Connection string alternative (broader credential scope)
# AZURE_STORAGE_CONNECTION_STRING=
# Backup schedule in cron format: "minute hour * * *" (UTC)
BACKUP_SCHEDULE_CRON="0 3 * * *"
# Retain backups for this many days; older blobs are swept after each run
BACKUP_RETENTION_DAYS=14
