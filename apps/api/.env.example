PORT=3001
DATABASE_URL=postgresql://dnd-notes:change-me@localhost:5432/dnd-notes
SITE_ADMIN_EMAILS=you@example.com
PUBLIC_WEB_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Express trust-proxy setting. Set to `true` (or a hop count) when the API
# runs behind nginx ingress / load balancer so req.ip resolves from
# X-Forwarded-For. Required for per-client rate limiting to work. Leave
# false / unset for local `npm run dev`.
TRUST_PROXY=false
KEYCLOAK_URL=http://keycloak.127.0.0.1.nip.io:8080
KEYCLOAK_JWKS_URL=
KEYCLOAK_REALM=dnd-notes-dev
KEYCLOAK_TENANT_CLIENT_ID=dnd-notes-tenant-app
