# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
# Squad: worktrees folder (issue-specific checkouts)
.worktrees/

# Copilot_here: ignore user configuration
.copilot_here/

# Node / workspace output
node_modules/
apps/*/node_modules/
dist/
coverage/
npm-debug.log*

# Local environment files
.env
.env.local
.env.*.local
apps/*/.env
apps/*/.env.local
apps/*/.env.*.local

# Local app data
*.sqlite
*.sqlite-shm
*.sqlite-wal

