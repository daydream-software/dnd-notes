# Copy this file to .env (gitignored) and edit values for your local setup.
# Variables here are auto-loaded by all scripts/k3d/*.sh entry points
# (via scripts/k3d/_load-dotenv.sh) so you don't have to export them by hand.

# Path to mkcert's CA root (containing rootCA.pem and rootCA-key.pem).
# Required by `npm run k3d:up` for cert-manager to issue trusted dev certs.
#
# - macOS / Linux:    typically ~/.local/share/mkcert
# - WSL2 + mkcert on Windows host:
#   /mnt/c/Users/<YourUser>/AppData/Local/mkcert
#
# Run `mkcert -install` once on the host where your browsers run, so the
# CA gets added to your browser/OS trust store. Then point CAROOT at the
# directory mkcert reports via `mkcert -CAROOT`.
CAROOT=
